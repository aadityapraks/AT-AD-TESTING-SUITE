    { "id": "TC_SCRUM493_002", "title": "New Submissions Tab Shows Product Count", "priority": "High", "preconditions": "Admin is on Product Management page.", "steps": ["Observe the 'New Submissions' tab."], "expectedResults": ["Tab shows a numeric count."], "testResult": "PASS", "feature": "New Submissions Tab" },
    { "id": "TC_SCRUM493_003", "title": "Products Show Under Review Status", "priority": "Highest", "preconditions": "Admin clicks 'New Submissions' tab.", "steps": ["Click 'New Submissions' tab.", "Observe first product card."], "expectedResults": ["Product card displays 'Under Review' status."], "testResult": "PASS", "feature": "New Submissions Tab" },

      "wcagCriterion": "2.4.7",
      "componentElement": "",
      "priority": "High",
      "relatedJiraIssue": "SCRUM-24",
      "preconditions": "",
      "steps": [
        "Login as approved AP",
        "Navigate to Product Management page",
        "Tab to Delete Product button for owned product",
        "Verify focus indicator is visible",
        "Press Enter/Space to activate"
      ],
      "expectedResults": [
        "Delete button keyboard accessible",
        "Focus indicator has 3:1 contrast ratio (WCAG 2.4.7)",
        "Enter/Space activates button",
        "Button only available for owned products",
        "No keyboard traps exist"
